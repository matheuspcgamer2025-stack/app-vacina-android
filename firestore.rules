rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return lower(request.auth.token.email);
    }

    function validVaccinePayload(data) {
      return data.usuarioId is string
        && data.perfilId is string
        && data.nome is string
        && data.lote is string
        && data.local is string
        && data.data is string
        && data.dataRegistro is string
        && (!('proximaDose' in data) || data.proximaDose == null || data.proximaDose is string);
    }

    match /vacinas/{vacinaId} {
      allow create: if isSignedIn()
        && validVaccinePayload(request.resource.data)
        && request.resource.data.usuarioId == userEmail();

      allow read, update, delete: if isSignedIn()
        && resource.data.usuarioId is string
        && resource.data.usuarioId == userEmail();
    }
  }
}
